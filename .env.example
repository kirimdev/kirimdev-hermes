# Kirimdev Hermes plugin — contoh konfigurasi
# Salin ke ~/.hermes/.env atau: hermes config set NAMA nilai
# Dokumentasi lengkap: README.md (root repo)

# ── Wajib ──
KIRIMDEV_API_KEY=kdv_live_xxxxxxxx
KIRIMDEV_WEBHOOK_SECRETS=whsec_xxxxxxxx
KIRIMDEV_ENABLED_NUMBERS=123456789012345

# ── Disarankan ──
KIRIMDEV_DEFAULT_PHONE_NUMBER_ID=123456789012345
KIRIMDEV_PUBLIC_URL=https://hermes-webhooks.domain.com
KIRIMDEV_OWNER_USERS=628123456789

# ── Authorization (opsional) ──
# KIRIMDEV_ALLOWED_USERS=628111111111,628222222222
# KIRIMDEV_ALLOW_ALL_USERS=false
# KIRIMDEV_OWNER_FULL_AGENT=true

# ── Jaringan (opsional) ──
# KIRIMDEV_HOST=0.0.0.0
# KIRIMDEV_PORT=8646
# KIRIMDEV_RATE_LIMIT_PER_MIN=15

# ── API (opsional) ──
# KIRIMDEV_API_BASE_URL=https://api.kirimdev.com/v1
# KIRIMDEV_DEFAULT_CHANNEL=whatsapp
# KIRIMDEV_HOME_CHANNEL=123456789012345:628123456789

# ── Human handoff v1.1+ (opsional) ──
# KIRIMDEV_HUMAN_HANDOFF_SECONDS=900

# ── Voice transcription v1.1+ (opsional) ──
# KIRIMDEV_VOICE_TRANSCRIBE=true
# OPENAI_API_KEY=sk-...

# ── File persisten (opsional) ──
# KIRIMDEV_GRANTS_FILE=~/.hermes/kirimdev_grants.json
# KIRIMDEV_PENDING_FILE=~/.hermes/kirimdev_pending.json
